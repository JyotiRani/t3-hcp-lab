{
  "info": {
    "name": "Logistics Integration API",
    "description": "Test suite for webMethods integration with AI agent",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "_exporter_id": "12345678"
  },
  "item": [
    {
      "name": "Authentication",
      "item": [
        {
          "name": "Health Check",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{API_URL}}/health",
              "host": ["{{API_URL}}"],
              "path": ["health"]
            }
          },
          "response": []
        }
      ]
    },
    {
      "name": "Shipment Analysis",
      "item": [
        {
          "name": "Analyze Delay - Success",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 200\", function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test(\"Response has required fields\", function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData).to.have.property('shipmentId');",
                  "    pm.expect(jsonData).to.have.property('analysisResult');",
                  "    pm.expect(jsonData.status).to.eql('success');",
                  "});",
                  "",
                  "pm.test(\"AI analysis is present\", function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.analysisResult).to.have.property('aiAnalysis');",
                  "    pm.expect(jsonData.analysisResult.aiAnalysis).to.be.a('string');",
                  "});",
                  "",
                  "pm.test(\"Response time is acceptable\", function () {",
                  "    pm.expect(pm.response.responseTime).to.be.below(5000);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "X-API-Key",
                "value": "{{API_KEY}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"shipmentId\": \"SHP-2024-001\",\n  \"orderId\": \"ORD-2024-001\",\n  \"currentLocation\": \"Chicago, IL\",\n  \"destination\": \"New York, NY\",\n  \"expectedDeliveryDate\": \"2024-03-31T18:00:00Z\",\n  \"currentStatus\": \"in_transit\",\n  \"delayReason\": \"Weather conditions\"\n}"
            },
            "url": {
              "raw": "{{API_URL}}/shipments/analyze-delay",
              "host": ["{{API_URL}}"],
              "path": ["shipments", "analyze-delay"]
            }
          },
          "response": []
        },
        {
